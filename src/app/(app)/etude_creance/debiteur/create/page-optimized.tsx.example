"use client"

/**
 * EXEMPLE D'UTILISATION DU FORMULAIRE OPTIMISÉ
 *
 * Ce fichier montre comment utiliser le nouveau système optimisé.
 * Pour activer, renommer en "page.tsx" et renommer l'ancien en "page.old.tsx"
 */

import * as React from "react"
import { Button } from "@/components/ui/button"
import { useRouter } from "next/navigation"
import { useToast } from "@chakra-ui/react"
import { useApiClient } from "@/hooks/useApiClient"
import { useSession } from "next-auth/react"
import { DebiteurService } from "@/services/debiteur.service"
import { DebiteurCreateRequest } from "@/types/debiteur"
import { useForm } from "react-hook-form"
import { zodResolver } from "@hookform/resolvers/zod"
import { z } from "zod"

// Imports du nouveau système
import { MultiStepForm, StepConfig } from "@/components/multi-step/MultiStepForm"
import { DebiteurFormProvider } from "@/components/debiteur-form-optimized/DebiteurFormContext"
import { DebiteurFormStep1 } from "@/components/debiteur-form-optimized/DebiteurFormStep1"
// import { DebiteurFormStep2Physical } from "@/components/debiteur-form-optimized/DebiteurFormStep2Physical"
// import { DebiteurFormStep2Moral } from "@/components/debiteur-form-optimized/DebiteurFormStep2Moral"
// import { DebiteurFormStep3 } from "@/components/debiteur-form-optimized/DebiteurFormStep3"

// Schémas de validation
const step1Schema = z.object({
  codeDebiteur: z.string().optional(),
  categorieDebiteur: z.string().min(1, "La catégorie débiteur est requise"),
  adressePostale: z.string().min(1, "L'adresse postale est requise"),
  email: z.string().email("Email invalide").min(1, "L'email est requis"),
  telephone: z.string().optional(),
  numeroCell: z.string().optional(),
  typeDebiteur: z.string().min(1, "Le type débiteur est requis"),
});

// TODO: Ajouter step2PhysiqueSchema, step2MoralSchema, step3Schema

export default function NouveauDebiteurPageOptimized() {
  const router = useRouter()
  const toast = useToast()
  const apiClient = useApiClient()
  const { data: session } = useSession()
  const [step, setStep] = React.useState(1)
  const [isSubmitting, setIsSubmitting] = React.useState(false)
  const [typeDebiteur, setTypeDebiteur] = React.useState<string>('')

  // Form avec validation Zod
  const { control, handleSubmit: hookFormSubmit, formState: { errors }, trigger, watch, getValues } = useForm({
    resolver: zodResolver(step1Schema), // TODO: Switch schema based on step
    defaultValues: {},
    mode: 'onChange'
  })

  // Watch typeDebiteur pour affichage conditionnel step 2
  React.useEffect(() => {
    const subscription = watch((value) => {
      if (value.typeDebiteur) {
        setTypeDebiteur(value.typeDebiteur)
      }
    })
    return () => subscription.unsubscribe()
  }, [watch])

  // Configuration des steps avec validation
  const steps: StepConfig[] = [
    {
      id: 1,
      title: "Informations générales",
      description: "Code, catégorie, adresse, email et type de débiteur",
      validate: async () => {
        console.log('🔍 Validation du step 1...')
        const result = await trigger()
        console.log('🔍 Résultat validation:', result)
        if (!result) {
          console.log('❌ Erreurs:', errors)
        }
        return result
      }
    },
    {
      id: 2,
      title: "Personne physique/morale",
      description: "Informations détaillées selon le type sélectionné",
      validate: async () => {
        // TODO: Implémenter validation step 2
        console.log('🔍 Validation du step 2...')
        return true
      }
    },
    {
      id: 3,
      title: "Domiciliation",
      description: "Type, compte, banque et agence",
      validate: async () => {
        // TODO: Implémenter validation step 3
        console.log('🔍 Validation du step 3...')
        return true
      }
    }
  ]

  const handleFinalSubmit = async () => {
    console.log("📤 Soumission finale du formulaire...")

    setIsSubmitting(true)

    try {
      const formData = getValues()

      // Ajouter l'utilisateur connecté au payload
      const payload = {
        ...formData,
        utilisateur: (session as any)?.user?.username || (session as any)?.user?.name
      }

      console.log("📦 Payload:", payload)

      // Appeler l'API pour créer le débiteur
      const response = await DebiteurService.create(apiClient, payload as DebiteurCreateRequest)

      console.log("✅ Réponse de l'API:", response)

      // Afficher l'alerte de succès
      toast({
        title: "Débiteur enregistré avec succès !",
        description: `Le débiteur ${response.data?.DEB_CODE || ''} a été créé avec succès.`,
        status: "success",
        duration: 5000,
        isClosable: true,
        position: "top",
      })

      // Rediriger vers la liste après un court délai
      setTimeout(() => {
        router.push("/etude_creance/debiteur/views")
      }, 1500)
    } catch (error: any) {
      console.error("❌ Erreur lors de la création du débiteur:", error)

      // Afficher l'erreur
      toast({
        title: "Erreur lors de l'enregistrement",
        description: error.response?.data?.error?.message || error.message || "Une erreur est survenue",
        status: "error",
        duration: 7000,
        isClosable: true,
        position: "top",
      })
    } finally {
      setIsSubmitting(false)
    }
  }

  return (
    <div className="min-h-screen bg-gray-50">
      <div className="mx-auto max-w-6xl px-6 py-6">
        {/* En-tête */}
        <div className="mb-8">
          <div className="flex items-center justify-between mb-2">
            <h1 className="text-2xl font-semibold" style={{ color: '#28A325' }}>
              Ajouter un débiteur (Optimisé)
            </h1>
            <Button
              onClick={() => router.push("/etude_creance/debiteur/views")}
              className="text-white px-24 py-4 text-base min-w-[120px]"
              style={{ backgroundColor: '#28A325', color: 'white' }}
            >
              Consulter
            </Button>
          </div>
        </div>

        {/* Provider pour les données du formulaire */}
        <DebiteurFormProvider>
          <div className="bg-white rounded-lg border p-6 shadow-sm">
            <MultiStepForm
              steps={steps}
              currentStep={step}
              onStepChange={setStep}
              onSubmit={handleFinalSubmit}
              isSubmitting={isSubmitting}
              onValidationError={(message) => {
                toast({
                  title: "Validation échouée",
                  description: message,
                  status: "error",
                  duration: 5000,
                  isClosable: true,
                  position: "top",
                })
              }}
            >
              {/* Affichage conditionnel du step */}
              {step === 1 && (
                <DebiteurFormStep1
                  control={control}
                  errors={errors}
                />
              )}

              {step === 2 && (
                <div>
                  {typeDebiteur === 'P' || typeDebiteur === 'physique' ? (
                    <div>Step 2 - Personne physique (TODO)</div>
                    // <DebiteurFormStep2Physical control={control} errors={errors} />
                  ) : (
                    <div>Step 2 - Personne morale (TODO)</div>
                    // <DebiteurFormStep2Moral control={control} errors={errors} />
                  )}
                </div>
              )}

              {step === 3 && (
                <div>Step 3 - Domiciliation (TODO)</div>
                // <DebiteurFormStep3 control={control} errors={errors} />
              )}
            </MultiStepForm>
          </div>
        </DebiteurFormProvider>
      </div>
    </div>
  )
}
